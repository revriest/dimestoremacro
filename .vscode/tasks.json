{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter: Run App",
      "type": "shell",
      "command": "flutter",
      "args": [
        "run"
      ],
      "problemMatcher": []
    },
    {
      "label": "Flutter: Analyze",
      "type": "shell",
      "command": "flutter",
      "args": [
        "analyze"
      ],
      "problemMatcher": [
        "$dart"
      ],
      "group": "test"
    },
    {
      "label": "Flutter: Test",
      "type": "shell",
      "command": "flutter",
      "args": [
        "test"
      ],
      "problemMatcher": [
        "$dart"
      ],
      "group": "test"
    },
    {
      "label": "Flutter: Dev Check (analyze + test)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "tooling/dev_check.ps1"
      ],
      "problemMatcher": [
        "$dart"
      ],
      "group": "test"
    },
    {
      "label": "Flutter: Preflight (clean + get + analyze + test + debug build)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "tooling/preflight.ps1"
      ],
      "problemMatcher": [
        "$dart"
      ]
    }
  ]
}